<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.plana.model.RegionMapper">

    <resultMap id="RegionResultMap" type="com.example.plana.dto.RegionDto">
        <id     property="regionId"   column="region_id"/>
        <result property="zdoCode"    column="zdo_code"/>
        <result property="zdoName"    column="zdo_name"/>
        <result property="siguCode"   column="sigu_code"/>
        <result property="siguName"   column="sigu_name"/>
        <result property="createDate" column="create_date"/>
        <result property="latestDate" column="latest_date"/>
        <result property="status"     column="status"/>
    </resultMap>
    <select id="selectAllRegions" resultMap="RegionResultMap">
        SELECT region_id, zdo_code, zdo_name, sigu_code, sigu_name,
        create_date, latest_date, status
        FROM PLANA_ADMIN.REGION
    </select>

</mapper>